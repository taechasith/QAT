# Public Supabase project URL. Safe for browser use.
NEXT_PUBLIC_SUPABASE_URL=

# Public Supabase publishable key. Safe for browser use.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only Supabase service role key. Do not expose to browser code.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only Resend key for update notification email.
RESEND_API_KEY=

# Sender address for notification email.
EMAIL_FROM=

# Optional server-only OpenAI key for later admin drafting tools.
OPENAI_API_KEY=

# Comma-separated allowlist for CMS access.
ADMIN_EMAILS=

# Optional public deployment URL after Vercel setup.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
